				{ AspectRatioFormats::Cinemascope,				{ 21.0, 9.0 } },
				{ AspectRatioFormats::AmericanWide,				{ 1.85, 1.0 } },
				{ AspectRatioFormats::EuropeanWide,				{ 1.66, 1.0 } },
				{ AspectRatioFormats::MobilePortrait,			{ 9.0,	16.0}	},
				{ AspectRatioFormats::IMAX,								{ 1.43, 1.0 } }
		};

