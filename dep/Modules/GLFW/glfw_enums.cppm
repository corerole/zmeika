module;

export module glfw_enums;
import std;
import flags;
import madmap;

enum class AspectRatioFormats {
	Square,          // 1:1  (квадрат, соцсети)
	PAL,             // 4:3  (стандартное ТВ, фото 6x4.5)
	SXGA,            // 5:4  (мониторы 1280x1024)
	Classic35mm,     // 3:2  (классическая плёнка, фото 36x24 мм)
	Widescreen,      // 16:9 (HDTV, современные мониторы, YouTube)
	Widescreen16_10, // 16:10 (широкоформатные мониторы, ноутбуки)
	Cinemascope,     // 21:9 (ультраширокие мониторы, киноформат 2.35:1)
	AmericanWide,    // 1.85:1 (американский широкий экран)
	EuropeanWide,    // 1.66:1 (европейский широкий экран)
	MobilePortrait,  // 9:16 (вертикальное видео для смартфонов)
	IMAX,            // 1.43:1 (IMAX 70mm)
};

enum class Orientation : bool {
	Portait = false,
	Landscape = true,
};
					 
enum class FrameActionState : bool {
	disabled = false,
	enabled = true
};

enum class CursorState : unsigned {
	normal		= 0x00034001,
	hidden		= 0x00034002,
	disabled	= 0x00034003,
	captured	= 0x00034004
};

enum class CursorRawInput : bool {
	disabled = false,
	enabled = true
};

enum class CharMods : unsigned {
	shift			= 0x0001,
	control		= 0x0002,
	alt				= 0x0004,
	super			= 0x0008,
	caps_lock = 0x0010,
	num_lock	= 0x0020 // = 0x0012
};

template<> struct flags::FlagTraits<CharMods> {
	static constexpr bool isBitmask = true;
	static constexpr AllFlags<CharMods> allFlags{ .m_mask = 0x3F }; // 0x1F
};

enum class KeyState {
	release = 0,
	press = 1,
	repeat = 2,
	stick = 3
};

